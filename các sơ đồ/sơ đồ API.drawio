        </mxCell>

        <mxCell id="auth_header" value="AUTH API" style="swimlane;fontStyle=1;align=center;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="210" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="POST /auth/register" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#b85450;fontSize=10;" vertex="1" parent="auth_header">
